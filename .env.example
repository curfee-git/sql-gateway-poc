# Copy this file to `.env` and fill in the values for your deployment.
#
# The gateway refuses to boot unless DATABASE_ADAPTER and DATABASE_URL
# are set explicitly: no adapter has defaults, because the shape of
# the connection string depends on the chosen persistence system.

# ---- Required --------------------------------------------------------------

# Which database adapter to load. Must match a sub-package under
# src/infrastructure/persistence/. Ships with: postgres.
DATABASE_ADAPTER=postgres

# Connection string understood by the selected adapter.
# Postgres: postgresql://user:password@host:port/dbname
# MySQL (hypothetical): mysql://user:password@host:port/dbname
# MongoDB (hypothetical): mongodb://user:password@host:port/dbname
DATABASE_URL=postgresql://agent_rw:agent_pw@localhost:5432/demo

# ---- Optional --------------------------------------------------------------

# Upper bound on how long a single query may run, in milliseconds.
# Applies to SQL and NoSQL adapters alike.
QUERY_TIMEOUT_MS=5000

# Upper bound on records returned by a read (rows / documents / items).
MAX_RESULTS=1000

# Rows kept per allowed-query entry in the in-memory /observability buffer.
# The full result still flows through the HTTP response; this only caps the
# sample shown on the live demo page to keep memory bounded.
MAX_SAMPLE_ROWS_IN_OBSERVABILITY=20

# Optional absolute path of a PII-free JSONL file the gateway appends every
# observability entry to (same data as stdout, plus file durability across
# restarts). Leave empty to disable the file sink.
OBSERVABILITY_JSONL_PATH=
